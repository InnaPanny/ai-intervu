# Remote AI service. Without these values, the app uses local demo rules.
# Supported providers: deepseek, openai, openai-compatible, custom.
AI_PROVIDER=deepseek
AI_API_KEY=
AI_API_BASE_URL=https://api.deepseek.com
AI_MODEL_FAST=deepseek-v4-flash
AI_MODEL_QUALITY=deepseek-v4-pro

